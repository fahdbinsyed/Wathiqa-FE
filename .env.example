# Environment Configuration
# Copy this file to .env.local and update values

# Application Name
REACT_APP_NAME=Wathiqa Employee Desk Management System

# API Configuration (for future backend integration)
REACT_APP_API_URL=http://localhost:3001/api

# Feature Flags
REACT_APP_ENABLE_DARK_MODE=true
REACT_APP_ENABLE_MULTI_LANGUAGE=true
REACT_APP_ENABLE_NOTIFICATIONS=true

# Settings
REACT_APP_DEFAULT_REMINDER_DAYS=60
REACT_APP_COMPANY_NAME=My Company
